# Python
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# Build artifacts
# colcon writes build/, install/ and log/ into the workspace root. Without
# install/ and log/ here, a build on the Pi fills git status with thousands of
# generated files and `git add -A` will happily commit them.
build/
install/
log/
bin/
external/
*.o
*.so
*.a

# Executables
bt_tracker
orthanc_menu
orthanc
orthanc_tracker

# Runtime files (generated in build/)
build/detections.json
detections.json
*.log

# YOLO models (download separately, stored in build/)
build/*.pt
*.pt

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store

# Backup files
*.bak
*.backup